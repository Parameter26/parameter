# Contoh environment variables untuk project Parameter.
# Copy file ini jadi `.env.local` lalu isi value-nya. JANGAN commit .env.local.
# Value asli minta ke Alwa (lihat ONBOARDING.md).

# Google Service Account (buat WA Follow-up / akses Google Sheets)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# Google Sheet ID sumber leads
PARAM_LEADS_SHEET_ID=

# Key buat akses dashboard leads
LEADS_DASH_KEY=

# Secret buat proteksi endpoint cron
CRON_SECRET=

# Konfigurasi outreach
OUTREACH_FOLLOWUP_DAYS=
OUTREACH_DAILY_LIMIT=
SENDER_NAME=
